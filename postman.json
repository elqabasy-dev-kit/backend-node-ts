			"script": {
				"type": "text/javascript",
				"exec": [
					"if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'http://localhost:3030/api/v1');",
					"if (!pm.collectionVariables.get('accessToken')) pm.collectionVariables.set('accessToken', '');",
					"if (!pm.collectionVariables.get('refreshToken')) pm.collectionVariables.set('refreshToken', '');",
					"if (!pm.collectionVariables.get('challengeToken')) pm.collectionVariables.set('challengeToken', '');",
					"if (!pm.collectionVariables.get('username')) pm.collectionVariables.set('username', 'admin');",
					"if (!pm.collectionVariables.get('password')) pm.collectionVariables.set('password', 'password');",
					"if (!pm.collectionVariables.get('newPassword')) pm.collectionVariables.set('newPassword', 'password');",
					"if (!pm.collectionVariables.get('email')) pm.collectionVariables.set('email', 'admin@gmail.com');",
					"if (!pm.collectionVariables.get('fName')) pm.collectionVariables.set('fName', 'Driver');",
					"if (!pm.collectionVariables.get('lName')) pm.collectionVariables.set('lName', 'Demo');",
					"if (!pm.collectionVariables.get('phone')) pm.collectionVariables.set('phone', '+201000000000');"
				]
			}
		}
